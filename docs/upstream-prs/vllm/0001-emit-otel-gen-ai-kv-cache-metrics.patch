+                    "OTel: gen_ai.server.kv_cache.eviction_rate"
+                ),
+                labelnames=_kv_labels)
+
+            self._gauge_kv_allocation_velocity = prometheus_client.Gauge(
+                name="gen_ai_server_kv_cache_allocation_velocity",
+                documentation=(
+                    "KV cache growth rate in MB/s (positive = growing). "
+                    "OTel: gen_ai.server.kv_cache.allocation_velocity_mbps"
+                ),
+                labelnames=_kv_labels)
+
+            self._gauge_kv_preemption_rate = prometheus_client.Gauge(
+                name="gen_ai_server_scheduler_preemption_rate",
+                documentation=(
+                    "Sequence preemption rate (preemptions/s). "
+                    "OTel: gen_ai.server.scheduler.preemption_rate"
+                ),
+                labelnames=_kv_labels)
+
+            self._kv_collector = KVCacheMetricsCollector.from_engine_config(vllm_config)

     def record(
         self,
@@ -140,6 +178,28 @@ class PrometheusStatLogger(AggregateStatLoggerBase):
             self.metrics_info.labels(
                 model_name=model_name, engine=engine_label
             ).set(scheduler_stats.kv_cache_usage)
+
+            # OTel KV cache rate signals
+            if self._kv_collector is not None:
+                _rates = self._kv_collector.update(
