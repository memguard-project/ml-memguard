+                    ),
+                )
+                _lbl = dict(model_name=model_name, engine=engine_label)
+                self._gauge_kv_eviction_rate.labels(   # type: ignore[union-attr]
+                    **_lbl
+                ).set(_rates.eviction_rate)
+                self._gauge_kv_allocation_velocity.labels(  # type: ignore[union-attr]
+                    **_lbl
+                ).set(_rates.allocation_velocity_mbps)
+                self._gauge_kv_preemption_rate.labels(  # type: ignore[union-attr]
+                    **_lbl
+                ).set(_rates.preemption_rate)

         if iteration_stats is not None:
             # request-level histograms …
