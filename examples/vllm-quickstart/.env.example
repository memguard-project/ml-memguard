# --------------------------------------------------------------------------
# memguard vLLM quickstart — required variables
# --------------------------------------------------------------------------
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Your memguard cloud API key (get one at https://memguard.dev)
MEMGUARD_BACKEND_KEY=mg_your_key_here

# HuggingFace model ID to serve (must be accessible with HF_TOKEN)
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct

# HuggingFace access token (needed for gated models; safe to omit for public ones)
HF_TOKEN=hf_your_token_here

# --------------------------------------------------------------------------
# Optional overrides (defaults shown)
# --------------------------------------------------------------------------

# OOM probability above which the sidecar /readyz probe returns 503
# and Kubernetes stops routing new requests to this pod.
# MEMGUARD_SHED_THRESHOLD=0.70

# Seconds between KV cache polls
# MEMGUARD_POLL_INTERVAL=5.0

# vLLM inference server port (exposed on the host)
# VLLM_PORT=8000

# memguard sidecar port (Kubernetes readiness probe target)
# SIDECAR_PORT=8001
